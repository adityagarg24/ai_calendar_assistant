# Environment Variables for AI Calendar Assistant
# Copy this file to .env and fill in your actual values

# Claude AI API Key (Optional - for enhanced AI analysis)
CLAUDE_API_KEY=your_claude_api_key_here

# Alternative Claude API Key name (Vercel compatible)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Google Calendar API Credentials (Optional - for live calendar mode)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Flask Environment
FLASK_ENV=production

# Note: 
# - Demo mode works without any API keys
# - Live calendar mode requires Google credentials
# - Claude API key enhances AI analysis but app works without it